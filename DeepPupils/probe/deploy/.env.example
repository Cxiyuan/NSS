# ============================================================
# Probe 网络探针 — 生产环境配置
# 复制为 .env 并按需修改
#   cp .env.example .env && vi .env
# ============================================================

## Kafka broker 地址（逗号分隔支持多节点）
## 默认 localhost:9092（同一台机器的 Kafka）
PROBE_KAFKA_BROKERS=localhost:9092

## Kafka topic 名称
PROBE_KAFKA_TOPIC=probe

## Kafka-only 模式（true 时只输出到 Kafka，不写本地日志文件）
PROBE_KAFKA_ONLY=true

## 监听网卡接口（默认 ens192，按实际环境修改）
PROBE_INTERFACE=ens192

## Kafka 日志保留天数（默认 15 天）
KAFKA_LOG_RETENTION_DAYS=15

## 日志输出目录（宿主机挂载路径）
PROBE_LOG_DIR=/var/log/probe
