# ============================================
# Radar Web Crawler — 生产环境变量
# ============================================

# ─── 端口 ───────────────────────────────────
HOST_PORT=3000

# ─── SearXNG 自建搜索引擎（默认，免费无限） ─
SEARXNG_BASE_URL=http://127.0.0.1:4000

# ─── 代理（可选，用于绕过 IP 封禁） ─────────
HTTPS_PROXY=

# ─── 资源限制 ──────────────────────────────
MEMORY_LIMIT=2G
